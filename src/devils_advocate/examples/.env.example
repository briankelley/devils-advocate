# Devil's Advocate — environment variables
#
# Place this file alongside your models.yaml as ".env" (no .example suffix).
# It is auto-loaded at startup. Existing environment variables take precedence.
#
# Only set the keys for providers you've configured in models.yaml.

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT)
OPENAI_API_KEY=sk-...

# Google (Gemini) — API key from Google AI Studio
GOOGLE_API_KEY=AIza...

# xAI (Grok)
XAI_API_KEY=xai-...

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# Moonshot (Kimi)
MOONSHOT_API_KEY=sk-...

# MiniMax
MINIMAX_API_KEY=eyJ...
