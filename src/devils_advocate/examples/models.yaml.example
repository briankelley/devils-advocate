# ── Role Assignments ──────────────────────────────────────────────────
# Assign models from above to pipeline roles.
# You only need models you have API keys for.

roles:
  author: gpt-5.1
  reviewers:
    - claude-opus-4-6
    - gemini-3.1-pro-preview
  deduplication: claude-sonnet-4-5
  normalization: claude-haiku-4-5
  revision: deepseek-chat
  integration_reviewer: claude-opus-4-5
  # revision defaults to author if not set
  # normalization defaults to deduplication if not set
