# Devil's Advocate — models.yaml reference configuration
#
# This file contains every provider and model tested with dvad.
# You do NOT need all of these — configure only the models you have API keys for.
# At minimum you need: 1 author, 2 reviewers, 1 dedup model.
#
# API keys are resolved from environment variables only.
# Place a .env file alongside this config (see .env.example).
#
# Config locations (checked in order):
#   1. --config flag
#   2. ./models.yaml (project-local)
#   3. $DVAD_HOME/models.yaml
#   4. ~/.config/devils-advocate/models.yaml
#
# Run `dvad config --show` to validate your configuration.
#
# max_out_stated:     Vendor's documented max output token limit.
# max_out_configured: Your cap for dvad. Prevents runaway generation and cost.
#                     Must be <= max_out_stated. 16384 is a good default for
#                     review roles; revision may need more for large artifacts.

models:

  # ── Anthropic ────────────────────────────────────────────────────────

  claude-opus-4-6:
    provider: anthropic
    model_id: claude-opus-4-6
    api_key_env: ANTHROPIC_API_KEY
    context_window: 200000
    max_out_stated: 128000
    max_out_configured: 16384
    cost_per_1k_input: 0.005
    cost_per_1k_output: 0.025
    timeout: 900
    thinking: true

  claude-opus-4-5:
    provider: anthropic
    model_id: claude-opus-4-5
    api_key_env: ANTHROPIC_API_KEY
    context_window: 200000
