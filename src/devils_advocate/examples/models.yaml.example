# -- Role Assignments --------------------------------------------------
# Assign models from above to pipeline roles.
# You only need models you have API keys for.

roles:
  # Configure these in the GUI at http://localhost:8411/config
  #
  # Required: author, reviewers (at least 2), deduplication
  # Optional: normalization (defaults to dedup), revision (defaults to author),
  #           integration_reviewer
  author:
  reviewers: []
  deduplication:
  normalization:
  revision:
  integration_reviewer:

settings:
  live_testing: false
